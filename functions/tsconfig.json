{
    "compilerOptions": {
        "module": "Node16",
        "moduleResolution": "Node16",
        "esModuleInterop": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "skipLibCheck": true,
        "outDir": "lib",
        "sourceMap": true,
        "strict": true,
        "target": "es2017"
    },
    "compileOnSave": true,
    "include": [
        "src"
    ]
}