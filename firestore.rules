rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Challenges Collection
    match /challenges/{challengeId} {
      // Anyone can read worldwide challenges, only authenticated users can read friend challenges if they are in them (simplified here)
      allow read: if request.auth != null;
      // Challenges created by backend or host
      allow write: if request.auth != null && request.resource.data.hostId == request.auth.uid;
    }

    match /users/{userId} {
      
      // Users can only read their own profile document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Restrict what fields the user can update directly from the client.
      // Prohibit changing economics (diamonds), streak flags, and premium statuses.
      allow update: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['name', 'username', 'lastActiveDate']);

      // Only allow creation with safe default fields
      allow create: if request.auth != null 
                    && request.auth.uid == userId;

      // Subcollections rules
      
      // Habits: Full access to the owner
      match /habits/{habitId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Logs: Full access to the owner to record completions
      match /logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Analytics: Read-only, and only if Premium
      match /analytics/{docId} {
        allow read: if request.auth != null 
                    && request.auth.uid == userId
                    && get(/databases/$(database)/documents/users/$(userId)).data.isPremium == true;
        allow write: if false; // Only written by Cloud Functions
      }
      
      // Transactions: Read-only for the owner to see history
      match /transactions/{transactionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // ONLY generated by Backend Cloud Functions
      }
    }
  }
}
